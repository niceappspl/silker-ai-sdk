{
  "name": "@silker-ai/agent",
  "version": "1.6.0",
  "description": "Lightweight runtime security agent for AI-powered apps - detects anomalies, blocks attacks, and provides real-time protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    }
  },
  "bin": {
    "silker": "./dist/cli/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.js",
    "build": "tsc",
    "benchmark": "ts-node --project tsconfig.benchmark.json benchmark/run.ts --suite=core",
    "benchmark:extended": "ts-node --project tsconfig.benchmark.json benchmark/run.ts --suite=extended",
    "benchmark:generate": "node benchmark/scripts/generate-extended-samples.js",
    "benchmark:validate": "node benchmark/scripts/validate-datasets.js",
    "benchmark:all": "npm run benchmark:generate && npm run benchmark:validate && npm run benchmark && npm run benchmark:extended",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "jest --testPathPattern=tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "security",
    "runtime",
    "anomaly-detection",
    "api-security",
    "brute-force",
    "sql-injection",
    "xss"
  ],
  "author": "Silker AI",
  "license": "Apache-2.0",
  "homepage": "https://github.com/niceappspl/silker-ai-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/niceappspl/silker-ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/niceappspl/silker-ai-sdk/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "events": "^3.3.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "nock": "^13.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "CONFIGURATION.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
