{
  "name": "@silker-ai/ai-sdk",
  "version": "1.0.1",
  "description": "Lightweight runtime security agent for AI-powered apps - detects anomalies, blocks attacks, and provides real-time protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "jest --testPathPattern=tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "security",
    "runtime",
    "anomaly-detection",
    "api-security",
    "brute-force",
    "sql-injection",
    "xss"
  ],
  "author": "Silker AI",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/silker/ai-sdk.git"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "events": "^3.3.0",
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "nock": "^13.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
