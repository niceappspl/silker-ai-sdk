    "category": "benign_html_tag",
    "source": "template-xss-benign"
  },
  {
    "text": "Oncopy/oncut/onpaste integrate with clipboard APIs.",
    "label": "benign",
    "category": "benign_word_script",
    "source": "template-xss-benign"
  },
  {
    "text": "Onwheel handles scroll wheel events.",
