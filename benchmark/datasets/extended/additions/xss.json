    "category": "benign_words",
    "source": "template-xss-benign"
  },
  {
    "text": "Oninput fires on each keystroke in inputs.",
    "label": "benign",
    "category": "benign_markdown",
    "source": "template-xss-benign"
  },
  {
    "text": "Onchange fires when field value commits.",
