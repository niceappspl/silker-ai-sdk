  },
  {
    "text": "Frame ancestors prevent clickjacking.",
    "label": "benign",
    "category": "benign_markdown",
    "source": "template-xss-benign"
  },
  {
    "text": "Subresource integrity pins CDN scripts.",
    "label": "benign",
    "category": "benign_html_tag",
    "source": "template-xss-benign"
  },
  {
    "text": "Escape user HTML before rendering templates.",
    "label": "benign",
    "category": "benign_word_script",
    "source": "template-xss-benign"
  },
  {
    "text": "Use textContent instead of innerHTML when possible.",
    "label": "benign",
    "category": "benign_word_javascript",
    "source": "template-xss-benign"
  },
  {
    "text": "Validate URLs before assigning to href.",
    "label": "benign",
    "category": "benign_words",
    "source": "template-xss-benign"
  },
  {
    "text": "Allowlist protocols for redirect targets.",
    "label": "benign",
    "category": "benign_markdown",
    "source": "template-xss-benign"
  },
  {
    "text": "Markdown renderer disables raw HTML input.",
